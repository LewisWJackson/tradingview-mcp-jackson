//@version=6
strategy("FORTRESS — Multi-Confluence Swing Engine", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=100000, pyramiding=0, commission_value=0.1)

// ══════════════════════════════════════════
// FORTRESS STRATEGY — Weekly Swing/Position
// Confluence Required: Ichimoku + MACD + RSI + ADX + EMA + Volume
// Only signals when 4+ indicators align
// Built for: BTC, Energy, Gold, Defensive stocks
// ══════════════════════════════════════════

// ─── INPUTS ───
grp1 = "═══ Ichimoku Cloud ═══"
tenkanLen   = input.int(9,   "Tenkan (Conversion)",  group=grp1)
kijunLen    = input.int(26,  "Kijun (Base)",         group=grp1)
senkouBLen  = input.int(52,  "Senkou B (Leading B)", group=grp1)
displacement= input.int(26,  "Displacement",         group=grp1)

grp2 = "═══ MACD ═══"
macdFast    = input.int(12,  "Fast",    group=grp2)
macdSlow    = input.int(26,  "Slow",    group=grp2)
macdSig     = input.int(9,   "Signal",  group=grp2)

grp3 = "═══ RSI ═══"
rsiLen      = input.int(14,  "Length",      group=grp3)
rsiOB       = input.int(70,  "Overbought",  group=grp3)
rsiOS       = input.int(30,  "Oversold",    group=grp3)

grp4 = "═══ Trend Filters ═══"
emaLen      = input.int(21,  "EMA Length",      group=grp4)
adxLen      = input.int(14,  "ADX Length",      group=grp4)
adxThresh   = input.int(20,  "ADX Trend Threshold", group=grp4)

grp5 = "═══ Volume Confirmation ═══"
volMaLen    = input.int(20,  "Volume MA Length", group=grp5)
volMult     = input.float(1.2, "Volume Surge Multiplier", group=grp5, step=0.1)

grp6 = "═══ Risk Management ═══"
useATRStop  = input.bool(true, "Use ATR-based Stops",  group=grp6)
atrLen      = input.int(14,   "ATR Length",            group=grp6)
atrMult     = input.float(2.0,"ATR Stop Multiplier",   group=grp6, step=0.1)
tpMult      = input.float(3.0,"ATR Take Profit Mult",  group=grp6, step=0.1)
minConfluence = input.int(4,  "Min Signals Required (1-6)", group=grp6, minval=1, maxval=6)

// ─── ICHIMOKU CALCULATIONS ───
tenkan  = (ta.highest(high, tenkanLen) + ta.lowest(low, tenkanLen)) / 2
kijun   = (ta.highest(high, kijunLen) + ta.lowest(low, kijunLen)) / 2
senkouA = (tenkan + kijun) / 2
senkouB = (ta.highest(high, senkouBLen) + ta.lowest(low, senkouBLen)) / 2
chikou  = close

// Cloud values (current, not displaced for signal logic)
cloudTop    = math.max(senkouA[displacement], senkouB[displacement])
cloudBottom = math.min(senkouA[displacement], senkouB[displacement])

// ─── MACD ───
[macdLine, signalLine, histogram] = ta.macd(close, macdFast, macdSlow, macdSig)

// ─── RSI ───
rsi = ta.rsi(close, rsiLen)

// ─── EMA ───
ema = ta.ema(close, emaLen)

// ─── ADX (Directional Movement) ───
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)

// ─── VOLUME ───
volMA = ta.sma(volume, volMaLen)
volSurge = volume > volMA * volMult

// ─── ATR for stops ───
atr = ta.atr(atrLen)

// ══════════════════════════════════════════
// SIGNAL SCORING — Each indicator = 1 point
// Need minConfluence (default 4) to trigger
// ══════════════════════════════════════════

// --- BULLISH SIGNALS ---
bull_ichimoku = close > cloudTop and tenkan > kijun and close > kijun
bull_macd     = histogram > 0 and macdLine > signalLine
bull_rsi      = rsi > 40 and rsi < rsiOB  // Room to run, not overbought
bull_ema      = close > ema and ema > ema[1]  // Price above rising EMA
bull_adx      = adx > adxThresh and diPlus > diMinus  // Strong uptrend
bull_volume   = volSurge  // Volume confirms

bullScore = (bull_ichimoku ? 1 : 0) + (bull_macd ? 1 : 0) + (bull_rsi ? 1 : 0) + (bull_ema ? 1 : 0) + (bull_adx ? 1 : 0) + (bull_volume ? 1 : 0)

// --- BEARISH SIGNALS ---
bear_ichimoku = close < cloudBottom and tenkan < kijun and close < kijun
bear_macd     = histogram < 0 and macdLine < signalLine
bear_rsi      = rsi < 60 and rsi > rsiOS  // Room to fall, not oversold
bear_ema      = close < ema and ema < ema[1]  // Price below falling EMA
bear_adx      = adx > adxThresh and diMinus > diPlus  // Strong downtrend
bear_volume   = volSurge  // Volume confirms

bearScore = (bear_ichimoku ? 1 : 0) + (bear_macd ? 1 : 0) + (bear_rsi ? 1 : 0) + (bear_ema ? 1 : 0) + (bear_adx ? 1 : 0) + (bear_volume ? 1 : 0)

// --- ENTRY TRIGGERS (require confluence threshold + fresh cross) ---
bullTrigger = bullScore >= minConfluence and bullScore[1] < minConfluence
bearTrigger = bearScore >= minConfluence and bearScore[1] < minConfluence

// --- EARLY EXIT SIGNALS (divergence warnings) ---
bullExhaustion = rsi > rsiOB and histogram < histogram[1] and histogram[1] < histogram[2]  // RSI overbought + MACD fading
bearExhaustion = rsi < rsiOS and histogram > histogram[1] and histogram[1] > histogram[2]  // RSI oversold + MACD recovering

// ─── TK CROSS (Tenkan/Kijun) for additional timing ───
tkBullCross = ta.crossover(tenkan, kijun)
tkBearCross = ta.crossunder(tenkan, kijun)

// Refined entry: confluence met + TK cross or fresh MACD cross
macdBullCross = ta.crossover(histogram, 0)
macdBearCross = ta.crossunder(histogram, 0)

buySignal  = bullScore >= minConfluence and (tkBullCross or macdBullCross or bullTrigger)
sellSignal = bearScore >= minConfluence and (tkBearCross or macdBearCross or bearTrigger)

// ─── STRATEGY EXECUTION ───
if buySignal
    strategy.entry("Long", strategy.long)
    if useATRStop
        strategy.exit("TP/SL", "Long", stop=close - atr * atrMult, limit=close + atr * tpMult)

if sellSignal or bullExhaustion
    strategy.close("Long")

// ══════════════════════════════════════════
// VISUALS
// ══════════════════════════════════════════

// ─── Ichimoku Cloud ───
p1 = plot(senkouA, offset=displacement, color=color.new(color.green, 80), title="Senkou A")
p2 = plot(senkouB, offset=displacement, color=color.new(color.red, 80), title="Senkou B")
fill(p1, p2, color=senkouA > senkouB ? color.new(color.green, 90) : color.new(color.red, 90), title="Cloud")
plot(tenkan, color=color.new(color.aqua, 0), linewidth=1, title="Tenkan")
plot(kijun, color=color.new(color.red, 0), linewidth=1, title="Kijun")
plot(ema, color=color.new(color.yellow, 0), linewidth=2, title="EMA 21")

// ─── Confluence Score Dashboard ───
var table dash = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "FORTRESS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 60))
    table.cell(dash, 1, 0, str.tostring(bullScore) + " BULL / " + str.tostring(bearScore) + " BEAR", text_color=bullScore > bearScore ? color.lime : bearScore > bullScore ? color.red : color.gray, text_size=size.normal)

    table.cell(dash, 0, 1, "Ichimoku", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, bull_ichimoku ? "✓ BULL" : bear_ichimoku ? "✗ BEAR" : "— NEUTRAL", text_color=bull_ichimoku ? color.lime : bear_ichimoku ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 2, "MACD", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, bull_macd ? "✓ BULL" : bear_macd ? "✗ BEAR" : "— NEUTRAL", text_color=bull_macd ? color.lime : bear_macd ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 3, "RSI (" + str.tostring(rsi, "#.0") + ")", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, bull_rsi ? "✓ BULL" : bear_rsi ? "✗ BEAR" : rsi > rsiOB ? "⚠ OVERBOUGHT" : "⚠ OVERSOLD", text_color=bull_rsi ? color.lime : bear_rsi ? color.red : color.orange, text_size=size.small)

    table.cell(dash, 0, 4, "EMA 21", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, bull_ema ? "✓ ABOVE ↑" : bear_ema ? "✗ BELOW ↓" : "— FLAT", text_color=bull_ema ? color.lime : bear_ema ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 5, "ADX (" + str.tostring(adx, "#.0") + ")", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, bull_adx ? "✓ TREND ↑" : bear_adx ? "✗ TREND ↓" : "— WEAK", text_color=bull_adx ? color.lime : bear_adx ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 6, "Volume", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, volSurge ? "✓ SURGE" : "— NORMAL", text_color=volSurge ? color.lime : color.gray, text_size=size.small)

    table.cell(dash, 0, 7, "SIGNAL", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 60))
    string verdict = bullScore >= minConfluence ? "BUY ZONE (" + str.tostring(bullScore) + "/6)" : bearScore >= minConfluence ? "SELL ZONE (" + str.tostring(bearScore) + "/6)" : "WAIT — NO CONFLUENCE"
    color verdictCol = bullScore >= minConfluence ? color.lime : bearScore >= minConfluence ? color.red : color.gray
    table.cell(dash, 1, 7, verdict, text_color=verdictCol, text_size=size.normal, bgcolor=color.new(color.blue, 60))

    // Exhaustion warning
    string warn = bullExhaustion ? "⚠ BULL EXHAUSTION" : bearExhaustion ? "⚠ BEAR EXHAUSTION" : ""
    table.cell(dash, 0, 8, warn, text_color=color.orange, text_size=size.small)
    table.cell(dash, 1, 8, useATRStop ? "SL: " + str.tostring(close - atr * atrMult, "#.##") + " | TP: " + str.tostring(close + atr * tpMult, "#.##") : "", text_color=color.yellow, text_size=size.small)

// ─── Signal Markers ───
plotshape(buySignal,  title="BUY",  style=shape.labelup,   location=location.belowbar, color=color.new(color.green, 0), size=size.large, text="BUY", textcolor=color.white)
plotshape(sellSignal, title="SELL", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0),   size=size.large, text="SELL", textcolor=color.white)

// Exhaustion warnings
plotshape(bullExhaustion and not sellSignal, title="Bull Exhaustion", style=shape.diamond, location=location.abovebar, color=color.orange, size=size.small, text="EXIT?")
plotshape(bearExhaustion and not buySignal,  title="Bear Exhaustion", style=shape.diamond, location=location.belowbar, color=color.aqua,   size=size.small, text="BOTTOM?")

// ─── Background: Green when in buy zone, red when in sell zone ───
bgcolor(bullScore >= minConfluence ? color.new(color.green, 93) : bearScore >= minConfluence ? color.new(color.red, 93) : na)

// ─── ATR Stop/Target lines when in position ───
plot(strategy.position_size > 0 and useATRStop ? close - atr * atrMult : na, title="Stop Loss", color=color.red, linewidth=1, style=plot.style_cross)
plot(strategy.position_size > 0 and useATRStop ? close + atr * tpMult : na, title="Take Profit", color=color.green, linewidth=1, style=plot.style_cross)

// ─── Alerts ───
alertcondition(buySignal,  title="FORTRESS BUY",  message="FORTRESS BUY signal on {{ticker}} at {{close}}")
alertcondition(sellSignal, title="FORTRESS SELL", message="FORTRESS SELL signal on {{ticker}} at {{close}}")
alertcondition(bullExhaustion, title="Bull Exhaustion", message="EXIT WARNING on {{ticker}} — bull exhaustion at {{close}}")
