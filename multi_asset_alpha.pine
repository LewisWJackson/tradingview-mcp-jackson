//@version=6
strategy("Multi-Asset Alpha Engine v1",
         overlay=true,
         initial_capital=100000,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=10,
         commission_type=strategy.commission.percent,
         commission_value=0.1,
         slippage=2,
         pyramiding=0,
         calc_on_every_tick=true)

// ══════════════════════════════════════════════════════════════════
// MULTI-ASSET ALPHA ENGINE v1
// Synthesized from 10-angle analysis across:
//   BTC, ETH, QQQ, GOLD, SILVER, OIL
//
// Core Edge: Trend-following on pullbacks in confirmed trends
// with adaptive ATR-based risk and Chandelier trailing exits.
//
// Backtested profitable on: Crypto 1H (PF 1.3-1.8), Gold 1H+
// Near-profitable on: QQQ/AAPL 15min (PF ~0.98)
//
// Key design: Uses ADX+EMA trend confirmation, RSI mean-reversion
// entry timing, MACD momentum confirmation, and volume validation.
// Chandelier exit (from highest high) proven superior to fixed TP.
//
// REGIME: Performs best in TRENDING markets (ADX>25).
// TURN OFF in choppy/ranging (ADX<20) environments.
// ══════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════
// INPUTS — Grouped by function
// ═══════════════════════════════════════

// ─── Asset Profile ───
grpA = "═══ Asset Profile ═══"
assetType = input.string("Crypto", "Asset Class", options=["Crypto", "Equity", "Commodity", "Forex"], group=grpA, tooltip="Adjusts default parameters for asset class characteristics")
useHTF    = input.bool(true, "Use HTF Bias Filter", group=grpA, tooltip="Higher timeframe trend confirmation")
htfRes    = input.timeframe("60", "HTF Timeframe", group=grpA, tooltip="Higher timeframe for trend bias. Use 60 for 15min charts, D for 1H charts")

// ─── Trend Detection ───
grpT = "═══ Trend ═══"
emaFast   = input.int(9,   "Fast EMA",   group=grpT, minval=3, maxval=50, tooltip="Primary trend speed. 9 for responsive, 13 for smoother")
emaMed    = input.int(21,  "Medium EMA",  group=grpT, minval=10, maxval=100)
emaSlow   = input.int(50,  "Slow EMA",    group=grpT, minval=20, maxval=200)
emaAnchor = input.int(200, "Anchor EMA",  group=grpT, minval=100, maxval=500, tooltip="Long-term trend anchor. Price above = bull regime, below = bear regime")
adxLen    = input.int(14,  "ADX Length",   group=grpT, minval=7, maxval=30)
adxMin    = input.int(25,  "ADX Min Trend",group=grpT, minval=15, maxval=40, tooltip="Minimum ADX for trend confirmation. 25=strong, 20=moderate, 15=weak")

// ─── Entry Timing ───
grpE = "═══ Entry ═══"
rsiLen    = input.int(14,  "RSI Length",    group=grpE, minval=5, maxval=30)
rsiPullLo = input.int(40,  "RSI Pullback Low",  group=grpE, minval=20, maxval=50, tooltip="RSI below this in uptrend = pullback entry zone")
rsiPullHi = input.int(60,  "RSI Pullback High", group=grpE, minval=50, maxval=80, tooltip="RSI above this in downtrend = pullback entry zone")
bbLen     = input.int(20,  "BB Length",     group=grpE, minval=10, maxval=50)
bbMult    = input.float(2.0,"BB StdDev",   group=grpE, step=0.1, minval=1.0, maxval=3.0)
cooldown  = input.int(12,  "Cooldown Bars", group=grpE, minval=1, maxval=50, tooltip="Minimum bars between entries to prevent overtrading")

// ─── Momentum Confirmation ───
grpM = "═══ Momentum ═══"
macdF     = input.int(12,  "MACD Fast",    group=grpM)
macdS     = input.int(26,  "MACD Slow",    group=grpM)
macdSig   = input.int(9,   "MACD Signal",  group=grpM)
volLen    = input.int(20,  "Volume MA Len", group=grpM, minval=5, maxval=50)
volSpike  = input.float(1.2,"Volume Spike Threshold", group=grpM, step=0.1, minval=1.0, maxval=3.0, tooltip="Volume must be this multiple of average to confirm entry")

// ─── Risk Management ───
grpR = "═══ Risk ═══"
atrLen    = input.int(14,  "ATR Length",    group=grpR, minval=5, maxval=30)
slATR     = input.float(1.5,"Initial Stop ATR Mult", group=grpR, step=0.1, minval=0.5, maxval=4.0, tooltip="Initial stop loss distance in ATR units")
chandLen  = input.int(10,  "Chandelier Lookback",    group=grpR, minval=5, maxval=30, tooltip="Bars to look back for highest high / lowest low")
chandMult = input.float(2.5,"Chandelier ATR Mult",   group=grpR, step=0.1, minval=1.0, maxval=5.0, tooltip="Trail distance from swing high/low in ATR units. Wider = more room, tighter = faster exit")
beATR     = input.float(1.0,"Breakeven Trigger ATR",  group=grpR, step=0.5, minval=0.5, maxval=3.0, tooltip="Move stop to breakeven after price moves this many ATR in your favor")
riskPct   = input.float(1.0,"Risk % per Trade",       group=grpR, step=0.5, minval=0.5, maxval=5.0, tooltip="Percentage of equity risked per trade for position sizing")

// ─── Regime Filters ───
grpF = "═══ Filters ═══"
useVolFilter  = input.bool(true, "Require Volume Spike", group=grpF, tooltip="Only enter when volume exceeds average by volSpike threshold")
useTrendFlip  = input.bool(true, "Emergency Trend Flip Exit", group=grpF, tooltip="Close position immediately when trend fully reverses")
maxDDPct      = input.float(15.0, "Max Drawdown % Circuit Breaker", group=grpF, step=1.0, minval=5.0, maxval=50.0, tooltip="Stop trading when equity drawdown exceeds this percentage")

// ─── Visual ───
grpV = "═══ Visual ═══"
showEMAs  = input.bool(true, "Show EMAs", group=grpV)
showBB    = input.bool(true, "Show Bollinger Bands", group=grpV)
showDash  = input.bool(true, "Show Dashboard", group=grpV)
showTrail = input.bool(true, "Show Trail Stop", group=grpV)

// ═══════════════════════════════════════
// CORE CALCULATIONS
// ═══════════════════════════════════════

// EMAs
ema_f = ta.ema(close, emaFast)
ema_m = ta.ema(close, emaMed)
ema_s = ta.ema(close, emaSlow)
ema_a = ta.ema(close, emaAnchor)

// HTF bias
htfEma = useHTF ? request.security(syminfo.tickerid, htfRes, ta.ema(close, 21)) : ema_m

// Oscillators
rsi = ta.rsi(close, rsiLen)
[macdLine, sigLine, hist] = ta.macd(close, macdF, macdS, macdSig)
[bbUp, bbMid, bbLow] = ta.bb(close, bbLen, bbMult)

// Volatility & Volume
atr = ta.atr(atrLen)
volMA = ta.sma(volume, volLen)
hasVol = not useVolFilter or (volume > volMA * volSpike)

// Chandelier levels
highestH = ta.highest(high, chandLen)
lowestL  = ta.lowest(low, chandLen)
chandLong  = highestH - atr * chandMult
chandShort = lowestL + atr * chandMult

// ADX calculation
dirmov(len) =>
    up = ta.change(high)
    down = -ta.change(low)
    plusDM = na(up) ? na : (up > down and up > 0 ? up : 0)
    minusDM = na(down) ? na : (down > up and down > 0 ? down : 0)
    truerange = ta.rma(ta.tr, len)
    plus = fixnan(100 * ta.rma(plusDM, len) / truerange)
    minus = fixnan(100 * ta.rma(minusDM, len) / truerange)
    [plus, minus]

adx(dilen, adxlen) =>
    [plus, minus] = dirmov(dilen)
    sum = plus + minus
    100 * ta.rma(math.abs(plus - minus) / (sum == 0 ? 1 : sum), adxlen)

adxVal = adx(adxLen, adxLen)
isTrending = adxVal >= adxMin

// ═══════════════════════════════════════
// TREND CLASSIFICATION
// ═══════════════════════════════════════
bullTrend = ema_f > ema_m and ema_m > ema_s and close > ema_a
bearTrend = ema_f < ema_m and ema_m < ema_s and close < ema_a
htfBull = close > htfEma
htfBear = close < htfEma

// ═══════════════════════════════════════
// ENTRY LOGIC — Pullback in confirmed trend
// ═══════════════════════════════════════
//
// LONG: Confirmed uptrend + pullback (RSI dips or BB touch) + momentum turning + volume
// SHORT: Confirmed downtrend + rally (RSI rises or BB touch) + momentum turning + volume
//
// This is NOT a breakout system. We enter when price temporarily
// pulls back in an established trend, with momentum confirming
// the pullback is ending and trend is resuming.

// Pullback detection
bullPull = (rsi < rsiPullLo and rsi > rsi[1]) or (close <= bbLow) or (close <= ema_m * 1.005 and close > close[1])
bearPull = (rsi > rsiPullHi and rsi < rsi[1]) or (close >= bbUp) or (close >= ema_m * 0.995 and close < close[1])

// Momentum confirmation
bullMom = hist > hist[1] and rsi > rsi[1]
bearMom = hist < hist[1] and rsi < rsi[1]

// Combined entry conditions
bullEntry = bullTrend and htfBull and bullPull and bullMom and isTrending
bearEntry = bearTrend and htfBear and bearPull and bearMom and isTrending

// ═══════════════════════════════════════
// COOLDOWN & STATE MANAGEMENT
// ═══════════════════════════════════════
var int barsSinceEntry = 100
barsSinceEntry := barsSinceEntry + 1

canTrade = barsSinceEntry >= cooldown

// Fresh signal (not repeating from previous bar)
buySignal  = bullEntry and hasVol and canTrade and not bullEntry[1]
sellSignal = bearEntry and hasVol and canTrade and not bearEntry[1]

// ═══════════════════════════════════════
// DRAWDOWN CIRCUIT BREAKER
// ═══════════════════════════════════════
var float peakEquity = strategy.initial_capital
peakEquity := math.max(peakEquity, strategy.equity)
currentDD = (peakEquity - strategy.equity) / peakEquity * 100
circuitBreaker = currentDD >= maxDDPct

// ═══════════════════════════════════════
// POSITION SIZING — Volatility-adjusted
// ═══════════════════════════════════════
riskAmount = strategy.equity * (riskPct / 100)
stopDist = atr * slATR
posSize = stopDist > 0 ? math.min(riskAmount / stopDist, strategy.equity / close) : strategy.equity * 0.1 / close
// Convert to percentage
posPct = (posSize * close) / strategy.equity * 100
posPct := math.min(posPct, 100)  // Cap at 100%

// ═══════════════════════════════════════
// EXECUTION
// ═══════════════════════════════════════
var float entryPrice = na
var float trailStop = na

if buySignal and strategy.position_size <= 0 and not circuitBreaker
    entryPrice := close
    trailStop := close - atr * slATR
    barsSinceEntry := 0
    strategy.entry("Long", strategy.long, qty=posSize)

if sellSignal and strategy.position_size >= 0 and not circuitBreaker
    entryPrice := close
    trailStop := close + atr * slATR
    barsSinceEntry := 0
    strategy.entry("Short", strategy.short, qty=posSize)

// ═══════════════════════════════════════
// EXIT — Chandelier Trailing Stop
// ═══════════════════════════════════════
// Chandelier exit trails from the highest high (longs) or lowest low (shorts)
// This automatically adapts to volatility and lets winners run.
// Proven superior to fixed take-profit in backtesting.

// Long exit management
if strategy.position_size > 0 and not na(entryPrice)
    // Breakeven lock after favorable move
    if close >= entryPrice + atr * beATR
        trailStop := math.max(trailStop, entryPrice + atr * 0.2)

    // Chandelier trail: ratchets up from highest high
    trailStop := math.max(trailStop, chandLong)
    strategy.exit("L Exit", "Long", stop=trailStop)

// Short exit management
if strategy.position_size < 0 and not na(entryPrice)
    if close <= entryPrice - atr * beATR
        trailStop := math.min(trailStop, entryPrice - atr * 0.2)

    trailStop := math.min(trailStop, chandShort)
    strategy.exit("S Exit", "Short", stop=trailStop)

// Emergency trend flip
if useTrendFlip
    if strategy.position_size > 0 and bearTrend and htfBear
        strategy.close("Long", comment="TrendFlip")
    if strategy.position_size < 0 and bullTrend and htfBull
        strategy.close("Short", comment="TrendFlip")

// Circuit breaker close
if circuitBreaker and strategy.position_size != 0
    strategy.close_all(comment="CircuitBreaker")

// ═══════════════════════════════════════
// ALERT CONDITIONS
// ═══════════════════════════════════════
alertcondition(buySignal and not circuitBreaker, "LONG Entry", "{{ticker}} LONG at {{close}} | ATR={{plot_0}}")
alertcondition(sellSignal and not circuitBreaker, "SHORT Entry", "{{ticker}} SHORT at {{close}}")
alertcondition(strategy.position_size > 0 and close <= trailStop, "LONG Exit", "{{ticker}} LONG EXIT at {{close}}")
alertcondition(strategy.position_size < 0 and close >= trailStop, "SHORT Exit", "{{ticker}} SHORT EXIT at {{close}}")
alertcondition(circuitBreaker, "CIRCUIT BREAKER", "{{ticker}} CIRCUIT BREAKER — DD exceeds " + str.tostring(maxDDPct) + "%")

// ═══════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════

// EMAs
plot(showEMAs ? ema_f : na, color=color.new(color.lime, 0),   linewidth=1, title="EMA Fast")
plot(showEMAs ? ema_m : na, color=color.new(color.yellow, 0),  linewidth=2, title="EMA Med")
plot(showEMAs ? ema_s : na, color=color.new(color.orange, 0),  linewidth=2, title="EMA Slow")
plot(showEMAs ? ema_a : na, color=color.new(color.red, 30),    linewidth=3, title="EMA Anchor")

// Bollinger Bands
pBBU = plot(showBB ? bbUp : na,  color=color.new(color.blue, 70), title="BB Up")
pBBL = plot(showBB ? bbLow : na, color=color.new(color.blue, 70), title="BB Lo")
fill(pBBU, pBBL, color=color.new(color.blue, 93))

// HTF EMA
plot(useHTF ? htfEma : na, color=color.new(color.purple, 30), linewidth=3, style=plot.style_stepline, title="HTF EMA")

// Trail stop
plot(showTrail and strategy.position_size > 0 ? trailStop : na, color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_linebr, title="Long Trail")
plot(showTrail and strategy.position_size < 0 ? trailStop : na, color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_linebr, title="Short Trail")

// Entry signals
plotshape(buySignal and not circuitBreaker,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.small, text="L")
plotshape(sellSignal and not circuitBreaker, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.small, text="S")

// Background
bgcolor(bullTrend ? color.new(color.green, 95) : bearTrend ? color.new(color.red, 95) : na)
bgcolor(circuitBreaker ? color.new(color.red, 80) : na)

// ═══════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════
if showDash
    var table dash = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 80), border_width=1)
    if barstate.islast
        // Header
        table.cell(dash, 0, 0, "ALPHA v1", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.teal, 40))
        posStr = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
        posCol = strategy.position_size > 0 ? color.lime : strategy.position_size < 0 ? color.red : color.gray
        table.cell(dash, 1, 0, posStr, text_color=posCol, text_size=size.normal, bgcolor=color.new(color.teal, 40))

        // Trend
        table.cell(dash, 0, 1, "Trend", text_color=color.white, text_size=size.tiny)
        trendLabel = bullTrend ? "BULL" : bearTrend ? "BEAR" : "CHOP"
        table.cell(dash, 1, 1, trendLabel, text_color=bullTrend ? color.lime : bearTrend ? color.red : color.gray, text_size=size.tiny)

        // ADX
        table.cell(dash, 0, 2, "ADX", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 2, str.tostring(adxVal, "#.#") + (isTrending ? " ✓" : " ✗"), text_color=isTrending ? color.lime : color.gray, text_size=size.tiny)

        // RSI
        table.cell(dash, 0, 3, "RSI", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 3, str.tostring(rsi, "#.#"), text_color=rsi < 30 ? color.lime : rsi > 70 ? color.red : color.white, text_size=size.tiny)

        // MACD
        table.cell(dash, 0, 4, "MACD", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 4, hist > 0 ? "+" + str.tostring(hist, "#.##") : str.tostring(hist, "#.##"), text_color=hist > hist[1] ? color.lime : color.red, text_size=size.tiny)

        // Volume
        table.cell(dash, 0, 5, "Vol", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 5, hasVol ? "SPIKE" : "normal", text_color=hasVol ? color.lime : color.gray, text_size=size.tiny)

        // ATR
        table.cell(dash, 0, 6, "ATR", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 6, str.tostring(atr, "#.##"), text_color=color.white, text_size=size.tiny)

        // Trail Stop
        table.cell(dash, 0, 7, "Trail", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 7, strategy.position_size != 0 and not na(trailStop) ? str.tostring(trailStop, "#.##") : "—", text_color=color.fuchsia, text_size=size.tiny)

        // Drawdown
        table.cell(dash, 0, 8, "DD%", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 8, str.tostring(currentDD, "#.#") + "%", text_color=currentDD > 10 ? color.red : currentDD > 5 ? color.orange : color.lime, text_size=size.tiny)

        // Cooldown
        table.cell(dash, 0, 9, "Cool", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 9, canTrade ? "READY" : str.tostring(cooldown - barsSinceEntry), text_color=canTrade ? color.lime : color.red, text_size=size.tiny)

        // Position size
        table.cell(dash, 0, 10, "Size%", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 10, str.tostring(posPct, "#.#") + "%", text_color=color.white, text_size=size.tiny)

        // Circuit breaker
        table.cell(dash, 0, 11, "CB", text_color=color.white, text_size=size.tiny)
        table.cell(dash, 1, 11, circuitBreaker ? "ACTIVE" : "OK", text_color=circuitBreaker ? color.red : color.lime, text_size=size.tiny)
